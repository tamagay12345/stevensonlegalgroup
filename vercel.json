{
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [{"key": "Cache-Control", "value": "no-store, max-age=0"}]
    },
    {
      "source": "/assets/(.*)\\.js",
      "headers": [{"key": "Cache-Control", "value": "no-cache, max-age=0, must-revalidate"}]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [{"key": "Cache-Control", "value": "no-cache, max-age=0, must-revalidate"}]
    }
  ]
}
